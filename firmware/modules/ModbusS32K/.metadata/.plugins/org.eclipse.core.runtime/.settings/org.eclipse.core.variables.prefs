eclipse.preferences.version=1
org.eclipse.core.variables.valueVariables=<?xml version\="1.0" encoding\="UTF-8" standalone\="no"?>\r\n<valueVariables>\r\n    <valueVariable description\="Location of GNU utils" name\="MSYS_LOC" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/msys32/usr/bin"/>\r\n    <valueVariable description\="Location of the GNU 10.2 Arm32 build tools" name\="S32DS_ARM32_GNU_10_2_TOOLCHAIN_DIR" readOnly\="false" value\="${eclipse_home}../S32DS/build_tools/gcc_v10.2/gcc-10.2-arm32-eabi"/>\r\n    <valueVariable description\="Location of the Arm32 S32K1 build tools GNU 10.2" name\="S32DS_K1_ARM32_GNU_10_2_TOOLCHAIN_DIR" readOnly\="false" value\="${S32DS_ARM32_GNU_10_2_TOOLCHAIN_DIR}"/>\r\n</valueVariables>\r\n
